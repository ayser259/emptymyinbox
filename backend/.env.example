# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Supabase Database Configuration
# Get these values from your Supabase project settings:
# Project Settings > Database > Connection string (URI mode)
# Or use the individual values from Connection pooling or Direct connection
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432

# Alternative: Use connection string directly (if you prefer)
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Gmail API Settings
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
